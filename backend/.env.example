# ─── Solana Network ────────────────────────────────────────────────────────────
# HTTP RPC endpoint
RPC_URL=https://api.devnet.solana.com
# WebSocket RPC endpoint (used by the indexer for log subscriptions)
RPC_WS_URL=wss://api.devnet.solana.com

# ─── Program Identifiers ───────────────────────────────────────────────────────
# sss-token program ID
PROGRAM_ID=VuhEhakwgobFN7L3fJJJCu4HTrV1mahAt8MUxiPnxwB
# sss-transfer-hook program ID
TRANSFER_HOOK_PROGRAM_ID=5ADnkQpQx8NZwy8xXSqQW9jbahsQLgQBpTHqpbRTSYgV

# ─── Database ──────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file
DB_PATH=/data/sss.db

# ─── API Server ────────────────────────────────────────────────────────────────
PORT=3000
# Bearer token for admin endpoints
ADMIN_API_KEY=changeme_replace_with_secure_random

# ─── Indexer ───────────────────────────────────────────────────────────────────
# Operating mode: api | indexer | worker
MODE=api
# Optional comma-separated list of config pubkeys to watch; empty = all
WATCH_CONFIGS=

# ─── Webhook Worker ────────────────────────────────────────────────────────────
# HMAC-SHA256 signing key used for X-SSS-Signature headers
WEBHOOK_SECRET_KEY=changeme_replace_with_secure_random
# Maximum concurrent in-flight HTTP deliveries
WEBHOOK_CONCURRENCY=5
# Milliseconds between delivery queue sweeps
WEBHOOK_POLL_INTERVAL_MS=2000

# ─── Logging ───────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Set to "true" for human-readable pretty output (dev only)
LOG_PRETTY=false

# ─── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=production
