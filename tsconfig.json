{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["mocha", "chai", "node"],
    "paths": {
      "@stbr/sss-token": ["./sdk/core/src"],
      "@stbr/sss-privacy": ["./sdk/privacy/src"]
    }
  },
  "include": ["tests/**/*.ts", "sdk/**/*.ts"],
  "exclude": ["node_modules", "dist", "target"]
}
