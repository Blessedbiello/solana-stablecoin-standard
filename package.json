    "test:backend": "cd backend && yarn test",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/web3.js": "^1.95.8",
    "@solana/spl-token": "^0.4.12",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "prettier": "^3.4.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
