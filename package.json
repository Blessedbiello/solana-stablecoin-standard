{
  "name": "solana-stablecoin-standard",
  "version": "0.1.0",
  "description": "Solana Stablecoin Standard (SSS) — Open-source SDK and core standards for stablecoins on Solana",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "sdk/core",
    "sdk/privacy",
    "backend",
    "frontend",
    "tui"
